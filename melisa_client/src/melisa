#!/usr/bin/env bash
# ==============================================================================
# MELISA CLIENT ROUTER
# Description: Primary entry point for the MELISA Remote Management CLI.
#              Routes commands to appropriate sub-modules (auth, exec, sync).
# ==============================================================================

# Ensure robust pipeline execution
set -o pipefail

# Export library path so sub-modules (exec.sh, auth.sh) can access it globally
export MELISA_LIB="$HOME/.local/share/melisa"

# Fallback color definitions in case utils.sh fails to load
BOLD="\e[1m"
RED="\e[31m"
GREEN="\e[32m"
CYAN="\e[36m"
YELLOW="\e[33m"
RESET="\e[0m"

# 1. Pre-flight System Dependency Verification (Multi-Distro Safe Check)
# Ensures that fundamental networking and core utilities exist on the host OS
if ! command -v ssh >/dev/null 2>&1; then
    echo -e "${RED}[FATAL ERROR]${RESET} OpenSSH Client ('ssh') is not installed or not in PATH."
    echo -e "${YELLOW}Tip:${RESET} Install 'openssh-clients' (Fedora/RHEL) or 'openssh-client' (Ubuntu/Debian)."
    exit 1
fi

# 2. Pre-flight Module Verification (Anti-Silent Fail)
# Verifies all required dependencies exist before attempting execution
for module in "utils.sh" "auth.sh" "exec.sh"; do
    if [ ! -f "$MELISA_LIB/$module" ]; then
        echo -e "${RED}[FATAL ERROR]${RESET} Core module '${module}' is missing in ${MELISA_LIB}"
        echo -e "${YELLOW}Tip:${RESET} Please ensure the MELISA client is installed correctly."
        exit 1
    fi
done

# Source Core Modules
source "$MELISA_LIB/utils.sh"
source "$MELISA_LIB/auth.sh"
source "$MELISA_LIB/exec.sh"

# Initialize Authentication Subsystem (Assumes definition in auth.sh)
init_auth

# 3. Interactive Help Documentation
# Triggered if the user runs the command without any arguments
if [ "$#" -lt 1 ]; then
    echo -e "${BOLD}${CYAN}MELISA REMOTE MANAGER - CLI CLIENT${RESET}"
    echo -e "${BOLD}Usage:${RESET} melisa <command> [arguments]\n"

    echo -e "${BOLD}AUTHENTICATION & CONNECTIONS:${RESET}"
    echo "  auth add <name> <user@ip> : Register a new remote MELISA server"
    echo "  auth switch <name>        : Switch active session to another server"
    echo "  auth list                 : Display all registered remote servers"
    echo "  auth remove <name>        : Unregister and delete a remote server"

    echo -e "\n${BOLD}PROJECT SYNCHRONIZATION:${RESET}"
    echo "  clone <name> [--force]    : Clone a project workspace from the host"
    echo "  sync                      : Push local workspace modifications to the host"
    echo "  get <name> [--force]      : Pull the latest master data into local workspace"

    echo -e "\n${BOLD}REMOTE OPERATIONS (Executed on Active Server):${RESET}"
    echo "  run <container> <file>    : Execute a local script inside a remote container (Background)"
    echo "  run-tty <cont> <file>     : Execute a script interactively (Foreground/TTY)"
    echo "  upload <cont> <dir> <dst> : Transfer a local directory into a container namespace"
    echo "  shell                     : Open a direct interactive SSH shell to the MELISA host"
    echo "  --list / --active         : Enumerate provisioned containers on the active server"

    echo -e "\n${BOLD}TUNNEL & EXPOSE (Cross-Network Access):${RESET}"
    echo "  tunnel <cont> <port> [lp]  : Forward container HTTP port to localhost (works across networks)"
    echo "  tunnel-list                : Show all active SSH tunnels"
    echo "  tunnel-stop <cont> [port]  : Stop a running tunnel"
    
    echo -e "\n${YELLOW}Execute 'melisa <command> --help' for command-specific details.${RESET}"
    exit 1
fi

# 4. Command Routing & Argument Parsing
COMMAND=$1
shift # Consume the main command so $@ only contains the trailing arguments

case $COMMAND in
    auth)
        SUB=$1; shift
        case $SUB in
            add)    
                # Safety Guard: Ensure both Name and IP are provided
                if [ -z "$1" ] || [ -z "$2" ]; then
                    echo -e "${RED}[ERROR]${RESET} Missing arguments. Usage: melisa auth add <name> <user@ip>"
                    exit 1
                fi
                auth_add "$1" "$2" 
                ;;
            switch) 
                if [ -z "$1" ]; then
                    echo -e "${RED}[ERROR]${RESET} Missing server name. Usage: melisa auth switch <name>"
                    exit 1
                fi
                auth_switch "$1" 
                ;;
            list)   
                auth_list 
                ;;
            remove) 
                if [ -z "$1" ]; then
                    echo -e "${RED}[ERROR]${RESET} Missing server name. Usage: melisa auth remove <name>"
                    exit 1
                fi
                auth_remove "$1" 
                ;;
            *)      
                echo -e "${RED}[ERROR]${RESET} Unknown auth command. Valid options: [add | switch | list | remove]" 
                exit 1
                ;;
        esac
        ;;
    
    clone)   exec_clone "$@" ;; 
    sync)    exec_sync "$@" ;;  
    get)     exec_get "$@" ;;
    
    run)     
        # Safety Guard: Prevent silent failures if file paths are omitted
        if [ -z "$1" ] || [ -z "$2" ]; then
            echo -e "${RED}[ERROR]${RESET} Usage: melisa run <container_name> <local_file_path>"
            exit 1
        fi
        exec_run "$1" "$2" 
        ;;
    
    run-tty) 
        if [ -z "$1" ] || [ -z "$2" ]; then
            echo -e "${RED}[ERROR]${RESET} Usage: melisa run-tty <container_name> <local_file_path>"
            exit 1
        fi
        exec_run_tty "$1" "$2" 
        ;;
    
    upload)  
        if [ -z "$1" ] || [ -z "$2" ] || [ -z "$3" ]; then
            echo -e "${RED}[ERROR]${RESET} Usage: melisa upload <container_name> <local_dir> <destination_path>"
            exit 1
        fi
        exec_upload "$1" "$2" "$3" 
        ;;
    
    shell) 
        # Validate that a connection string actually exists before launching SSH
        ensure_connected
        if [ -z "$CONN" ]; then
            echo -e "${RED}[FATAL]${RESET} Connection string is empty. Please set an active server using 'melisa auth switch'."
            exit 1
        fi
        echo -e "${GREEN}[INFO]${RESET} Establishing secure shell connection to ${BOLD}$CONN${RESET}..."
        ssh -t "$CONN" 
        ;;

    tunnel)
        if [ -z "$1" ] || [ -z "$2" ]; then
            echo -e "${RED}[ERROR]${RESET} Usage: melisa tunnel <container> <remote_port> [local_port]"
            echo -e "  Example: melisa tunnel myapp 3000"
            echo -e "  Example: melisa tunnel myapp 8080 9090   # different local port"
            exit 1
        fi
        exec_tunnel "$1" "$2" "${3:-}"
        ;;

    tunnel-list)
        exec_tunnel_list
        ;;

    tunnel-stop)
        if [ -z "$1" ]; then
            echo -e "${RED}[ERROR]${RESET} Usage: melisa tunnel-stop <container> [remote_port]"
            exit 1
        fi
        exec_tunnel_stop "$1" "${2:-}"
        ;;
        
    *) 
        # Fallback Router: If the command isn't recognized locally, 
        # forward the entire string directly to the remote MELISA host.
        exec_forward "$COMMAND" "$@" 
        ;;
esac